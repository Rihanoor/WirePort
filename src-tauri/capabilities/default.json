{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-toggle-maximize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-is-maximized",
    "opener:default",
    "wireport:allow-pick-parse-and-validate-file",
    "wireport:allow-save-profiles",
    "wireport:allow-load-profiles",
    "wireport:allow-generate-wireproxy-config",
    "wireport:allow-load-generated-config",
    "wireport:allow-start-wireproxy",
    "wireport:allow-stop-wireproxy",
    "wireport:allow-get-profile-status",
    "wireport:allow-set-selected-profile",
    "notification:default",
    "wireport:allow-test-proxy-connection",
    "wireport:allow-get-local-public-ip",
    "wireport:allow-get-profile-logs",
    "wireport:allow-clear-profile-logs",
    "wireport:allow-get-proxy-stats"
  ]
}
